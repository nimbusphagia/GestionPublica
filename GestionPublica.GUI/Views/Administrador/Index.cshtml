@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div class="page-title">Dashboard</div>
    <div class="page-subtitle">Resumen de actividad del sistema</div>
</div>

@if (TempData["Error"] != null)
{
    <div class="error-message">@TempData["Error"]</div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Solicitudes pendientes</div>
        <div class="stat-value warning">@ViewBag.TotalPendientes</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Finalizadas sin incidencia</div>
        <div class="stat-value accent">@ViewBag.FinalizadasSinIncidencia</div>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <span class="table-card-title">Accesos rápidos</span>
    </div>
    <div style="padding: 1.25rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a href="/Administrador/Solicitudes" class="btn btn-warning">Ver solicitudes pendientes</a>
        <a href="/Administrador/ReservasAprobadas" class="btn btn-primary">Ver reservas aprobadas</a>
        <a href="/Administrador/Incidencias" class="btn btn-secondary">Registrar incidencias</a>
    </div>
</div>
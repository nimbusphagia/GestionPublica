@model List<GestionPublica.BE.EspacioBE>
@{
    Layout = "~/Views/Shared/_LayoutSuperadmin.cshtml";
    ViewData["Title"] = "Espacios";
}

<div class="page-header">
    <div class="page-title">Gestión de Espacios</div>
    <div class="page-subtitle">Administra los espacios públicos del sistema</div>
</div>

@if (TempData["Error"] != null)
{
    <div class="error-message">@TempData["Error"]</div>
}

<div class="table-card">
    <div class="table-card-header">
        <span class="table-card-title">Espacios registrados</span>
        <button class="btn btn-primary" onclick="abrirModal('modal-crear-espacio')">+ Nuevo espacio</button>
    </div>
    <table>
        <thead>
        <tr>
            <th>Nombre</th>
            <th>Distrito</th>
            <th>Horario</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.Nombre</td>
                <td>@e.Distrito</td>
                <td>@e.HoraApertura.ToString(@"hh\:mm") - @e.HoraCierre.ToString(@"hh\:mm")</td>
                <td><span class="badge badge-@e.Estado">@e.Estado</span></td>
                <td class="table-actions">
                    <a href="/Superadmin/Instalaciones?idEspacio=@e.Id" class="btn btn-primary">Instalaciones</a>
                    <button class="btn btn-secondary"
                            onclick="abrirModalEditar(@e.Id, '@e.Nombre', '@e.Direccion', '@e.Distrito',
                            '@(e.Descripcion ?? "")',
                            '@e.HoraApertura.ToString(@"hh\:mm")',
                            '@e.HoraCierre.ToString(@"hh\:mm")')">
                        Editar
                    </button>
                    <form method="post" action="/Superadmin/ActualizarEstadoEspacio" id="form-estado-@e.Id">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@e.Id"/>
                        <select name="estado" class="select-estado"
                                onchange="document.getElementById('form-estado-@e.Id').submit()">
                            <option value="activo" @(e.Estado == "activo" ? "selected" : "")>Activo</option>
                            <option value="mantenimiento" @(e.Estado == "mantenimiento" ? "selected" : "")>
                                Mantenimiento
                            </option>
                            <option value="cerrado" @(e.Estado == "cerrado" ? "selected" : "")>Cerrado</option>
                        </select>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<!-- Modal crear espacio -->
<div class="modal-overlay" id="modal-crear-espacio">
    <div class="modal">
        <div class="modal-title">Nuevo espacio público</div>
        <form method="post" action="/Superadmin/CrearEspacio">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Nombre</label>
                <input type="text" name="Nombre" required/>
            </div>
            <div class="form-group">
                <label>Dirección</label>
                <input type="text" name="Direccion" required/>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Distrito</label>
                    <input type="text" name="Distrito" required/>
                </div>
                <div class="form-group">
                    <label>Descripción</label>
                    <input type="text" name="Descripcion"/>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Hora apertura</label>
                    <input type="time" name="HoraApertura" required/>
                </div>
                <div class="form-group">
                    <label>Hora cierre</label>
                    <input type="time" name="HoraCierre" required/>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary" onclick="cerrarModal('modal-crear-espacio')">Cancelar
                </button>
                <button type="submit" class="btn btn-primary">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal editar espacio -->
<div class="modal-overlay" id="modal-editar-espacio">
    <div class="modal">
        <div class="modal-title">Editar espacio</div>
        <form method="post" action="/Superadmin/EditarEspacio">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="editar-id"/>
            <div class="form-group">
                <label>Nombre</label>
                <input type="text" name="Nombre" id="editar-nombre" required/>
            </div>
            <div class="form-group">
                <label>Dirección</label>
                <input type="text" name="Direccion" id="editar-direccion" required/>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Distrito</label>
                    <input type="text" name="Distrito" id="editar-distrito" required/>
                </div>
                <div class="form-group">
                    <label>Descripción</label>
                    <input type="text" name="Descripcion" id="editar-descripcion"/>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label>Hora apertura</label>
                    <input type="time" name="HoraApertura" id="editar-apertura" required/>
                </div>
                <div class="form-group">
                    <label>Hora cierre</label>
                    <input type="time" name="HoraCierre" id="editar-cierre" required/>
                </div>
            </div>
            <div class="modal-actions">
                <button type="button" class="btn btn-secondary"
                        onclick="cerrarModal('modal-editar-espacio')">Cancelar
                </button>
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function abrirModal(id) {
            document.getElementById(id).classList.add('active');
        }

        function cerrarModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', e => {
                if (e.target === overlay) overlay.classList.remove('active');
            });
        });

        function abrirModalEditar(id, nombre, direccion, distrito, descripcion, apertura, cierre) {
            document.getElementById('editar-id').value = id;
            document.getElementById('editar-nombre').value = nombre;
            document.getElementById('editar-direccion').value = direccion;
            document.getElementById('editar-distrito').value = distrito;
            document.getElementById('editar-descripcion').value = descripcion;
            document.getElementById('editar-apertura').value = apertura;
            document.getElementById('editar-cierre').value = cierre;
            abrirModal('modal-editar-espacio');
        }
    </script>
}
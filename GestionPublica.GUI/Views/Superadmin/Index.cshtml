@{
    Layout = "~/Views/Shared/_LayoutSuperadmin.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div class="page-title">Dashboard</div>
    <div class="page-subtitle">Resumen general del sistema</div>
</div>

@if (TempData["Error"] != null)
{
    <div class="error-message">@TempData["Error"]</div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total espacios</div>
        <div class="stat-value accent">@ViewBag.TotalEspacios</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total usuarios</div>
        <div class="stat-value">@ViewBag.TotalUsuarios</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Penalidades activas</div>
        <div class="stat-value warning">@ViewBag.PenalidadesActivas</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Usuarios bloqueados</div>
        <div class="stat-value danger">@ViewBag.UsuariosBloqueados</div>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <span class="table-card-title">Accesos rápidos</span>
    </div>
    <div style="padding: 1.25rem; display: flex; gap: 0.75rem; flex-wrap: wrap;">
        <a href="/Superadmin/Espacios" class="btn btn-primary">Gestionar espacios</a>
        <a href="/Superadmin/Penalidades" class="btn btn-warning">Ver penalidades activas</a>
        <a href="/Superadmin/Usuarios" class="btn btn-secondary">Ver usuarios</a>
    </div>
</div>
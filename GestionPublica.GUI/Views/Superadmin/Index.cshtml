@{
    Layout = "~/Views/Shared/_LayoutSuperadmin.cshtml";
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div class="page-title">Dashboard</div>
    <div class="page-subtitle">Resumen general del sistema</div>
</div>

@if (TempData["Error"] != null)
{
    <div class="error-message">@TempData["Error"]</div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total espacios</div>
        <div class="stat-value accent">@ViewBag.TotalEspacios</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total usuarios</div>
        <div class="stat-value">@ViewBag.TotalUsuarios</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Penalidades activas</div>
        <div class="stat-value warning">@ViewBag.PenalidadesActivas</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Usuarios bloqueados</div>
        <div class="stat-value danger">@ViewBag.UsuariosBloqueados</div>
    </div>
</div>
